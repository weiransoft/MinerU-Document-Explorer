#!/usr/bin/env node

// Cross-platform CLI launcher (works on Windows, macOS, Linux).
// The previous #!/bin/sh version failed on Windows where sh is not available.
// See https://github.com/opendatalab/MinerU-Document-Explorer/issues/1

import { realpathSync } from "node:fs";
import { fileURLToPath } from "node:url";
import { dirname, join } from "node:path";
import { execFileSync } from "node:child_process";

const binDir = dirname(realpathSync(fileURLToPath(import.meta.url)));
const cli = join(binDir, "..", "dist", "cli", "qmd.js");

try {
  execFileSync(process.execPath, [cli, ...process.argv.slice(2)], {
    stdio: "inherit",
  });
} catch (err) {
  process.exitCode = err.status ?? 1;
}
